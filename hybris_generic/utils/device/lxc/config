lxc.rootfs.path = /home/phablet/openharmony/rootfs
lxc.uts.name = openharmony

lxc.log.level = 3
lxc.log.file = /home/phablet/openharmony/lxc.log

lxc.init.cmd = /init

lxc.environment = container=lxc
lxc.environment = HOME=/
lxc.environment = TERM=linux
lxc.environment = OHOS_RUNTIME_CONFIG=1

# IPC namespace: OHOS must share the Android container's IPC namespace so
# composer_host can reach hwservicemanager + HWC2 HIDL composer on /dev/hwbinder.
lxc.namespace.keep = net user
lxc.namespace.share.ipc = android

lxc.apparmor.profile = unconfined
lxc.autodev = 1

# PTY support: triggers LXC to mount a new devpts instance on /dev/pts and
# set up /dev/ptmx inside the container. Without this, /dev/pts is an empty
# directory and /dev/ptmx does not exist, so hdcd's interactive shell fails
# with "shell.cpp:261 Cannot open ptmx" -> "[Fail]Shell initialize failed".
lxc.pty.max = 1024

# Use dedicated OHOS binder devices (NOT /dev/binder which is a symlink to /dev/binderfs/binder).
# The host Android servicemanager registers as context manager on /dev/binderfs/binder first,
# so OHOS samgr must use separate devices to avoid binder context collision.
# These devices are created at boot by /home/phablet/openharmony/create_ohos_binder.py
# (run by ohos-binder-setup.service before ohos.service).
lxc.mount.entry = /dev/binderfs/ohos-binder dev/binder bind bind,create=file,optional 0 0
# hwbinder and vndbinder use the shared host devices so OHOS HDF VDI can reach Android HIDL services
# (registered on host hwservicemanager on /dev/hwbinder = /dev/binderfs/hwbinder).
# Only /dev/binder needs to be isolated because Android servicemanager collides with OHOS samgr.
lxc.mount.entry = /dev/binderfs/hwbinder dev/hwbinder bind bind,create=file,optional 0 0
lxc.mount.entry = /dev/binderfs/vndbinder dev/vndbinder bind bind,create=file,optional 0 0
lxc.mount.entry = /dev/ashmem dev/ashmem bind bind,create=file,optional 0 0
lxc.mount.entry = /dev/kmsg dev/kmsg bind bind,create=file,optional 0 0
# access_token_id: required for ATM (AccessTokenManager) to identify process tokens.
# Without this device, GetSelfTokenID() returns 0, causing InitHapToken to fail with
# ERR_PERMISSION_DENIED (201) and preventing all HAP pre-installation during first boot.
lxc.mount.entry = /dev/access_token_id dev/access_token_id bind bind,create=file,optional 0 0
lxc.mount.entry = proc proc proc nodev,noexec,nosuid 0 0
lxc.mount.entry = sysfs sys sysfs nodev,noexec,nosuid 0 0

lxc.mount.entry = /system  android/system  none bind,ro,create=dir,optional 0 0
lxc.mount.entry = /vendor  android/vendor  none bind,ro,create=dir,optional 0 0
lxc.mount.entry = /odm    android/odm     none bind,ro,create=dir,optional 0 0
lxc.mount.entry = /apex   apex            none rbind,ro,create=dir,optional 0 0
lxc.mount.entry = /dev/dma_heap  dev/dma_heap  none bind,create=dir,optional 0 0
lxc.mount.entry = /dev/mali0    dev/mali0    none bind,create=file,optional 0 0
lxc.mount.entry = /dev/dri      dev/dri      none rbind,create=dir,optional 0 0
lxc.mount.entry = /dev/input   dev/input    none rbind,create=dir,optional 0 0
lxc.mount.entry = /dev/rfkill  dev/rfkill   none bind,create=file,optional 0 0
# Phase 13B: native ALSA audio via alsa-lib — expose MTK sound card nodes
lxc.mount.entry = /dev/snd     dev/snd      none rbind,create=dir,optional 0 0

lxc.mount.entry = /dev/__properties__ dev/__properties__ none bind,create=dir,optional 0 0

# Android EGL implementations at /vendor/lib64/egl/ (Android libEGL.so uses hardcoded /vendor/ paths)
lxc.mount.entry = /vendor/lib64/egl  vendor/lib64/egl  none bind,ro,create=dir,optional 0 0

# Android gralloc/HIDL mapper HAL implementations at /vendor/lib64/hw/
# Required for GraphicBufferMapper (libui) to load the gralloc passthrough mapper via
# android_load_sphal_library("/vendor/lib64/hw/android.hardware.graphics.mapper@4.0-impl*.so").
# Both access() path-existence checks (in hw_get_module) and dlopen calls need the path to exist.
lxc.mount.entry = /vendor/lib64/hw  vendor/lib64/hw  none bind,ro,create=dir,optional 0 0

# NOTE: Android system EGL/GLES dispatch wrapper bind mounts intentionally absent.
# These were present in phase 5.7a but removed (2026-03-20) because they caused a
# critical namespace collision: OHOS's linker searches /system/lib64/ before
# /system/lib64/platformsdk/, so Android's libEGL.so (which needs libbacktrace.so)
# shadowed the OHOS opengl_wrapper's libEGL.so (in platformsdk/). Every OHOS service
# that links against libEGL.so (libwms, libbms, libresschedsvc, etc.) would fail to
# load with "Error loading shared library libbacktrace.so: (needed by libEGL.so)".
# Android libs (libGLES_mali.so etc.) resolve their EGL/GLES deps via the hybris
# Android linker, which remaps /system/lib64/ -> /android/system/lib64/ internally.

# Container-to-host shutdown propagation: OHOS init writes "poweroff" or
# "reboot" to /ohos-host-action before calling the reboot syscall (which the
# kernel otherwise converts into plain PID-namespace termination inside LXC).
# The host-side post-stop hook then invokes systemctl poweroff/reboot so the
# user-requested power action reaches Ubuntu Touch. See
# device/board/oniro/docs/hybris_generic/phase11_power_off_and_backlight_plan.md Fix 2.
lxc.mount.entry = /run/ohos-host-action ohos-host-action none bind,create=file,optional 0 0
lxc.hook.post-stop = /home/phablet/openharmony/ohos-post-stop.sh

# Make /storage/Users readable by normal apps (sharefs substitute).
# OHOS sandbox has two mounts for /storage/Users in appdata-sandbox.json:
#   - FILE_CROSS_APP         -> /mnt/user/<uid>/nosharefs/docs   (privileged only)
#   - FILE_ACCESS_COMMON_DIR -> /mnt/user/<uid>/sharefs/docs     (what normal apps see)
# On a real OHOS device storage_daemon stacks the kernel `sharefs` filesystem
# (fs/sharefs/) onto nosharefs/docs to produce sharefs/docs with per-URI
# permission filtering. Our Halium/MediaTek 5.10 kernel has no sharefs driver
# (`cat /proc/filesystems` only lists fuse), so sharefs/docs stays empty and
# apps like VLC open picker URIs and hit ENOENT.
# Pre-bind nosharefs/docs onto sharefs/docs at LXC mount time so every normal
# app sees the same files the file picker enumerates. storage_daemon's
# MountSharefs() early-exits when IsPathMounted(dst) is true, so this bind
# sticks across the daemon's own mount attempt. Every app that gets the
# FILE_ACCESS_COMMON_DIR sandbox mount sees all user files — no per-URI
# filtering — which matches the existing security posture of this build.
lxc.mount.entry = /home/phablet/openharmony/rootfs/mnt/user/100/nosharefs/docs mnt/user/100/sharefs/docs none bind,create=dir,optional 0 0

# External storage for the OHOS FileAccess extension (com.ohos.UserFile.ExternalFileManager).
# appspawn bind-mounts /mnt/data/external into the extension's per-app sandbox (as an
# "individual" section — required to succeed). Without a source path the extension process
# fails to spawn with "DoAppSandboxMountOnce section individual failed" and
# fileAccess.createFileAccessHelper() times out with 14300009. Pointing this at
# /home/phablet gives the picker access to the user's Ubuntu Touch media folders.
lxc.mount.entry = /home/phablet mnt/data/external none rbind,create=dir,optional 0 0

lxc.cgroup.devices.allow = a
lxc.cgroup2.devices.allow = a
