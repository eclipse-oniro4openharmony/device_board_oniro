CONFIG_HILOG=y
CONFIG_HILOG_BUFFER_SIZE=4096
CONFIG_HIEVENT=y
CONFIG_BBOX_BUFFER_SIZE=2048
CONFIG_HISYSEVENT=y
CONFIG_DFX_ZEROHUNG=y
CONFIG_DFX_HUNGTASK=y
CONFIG_DFX_HUNGTASK_USER=y

#
# Blackbox Options
#
CONFIG_BLACKBOX=y
CONFIG_BLACKBOX_LOG_ROOT_PATH=""
CONFIG_BLACKBOX_LOG_PART_REPRESENTATIVE=""
# CONFIG_BLACKBOX_STORAGE_BY_MEMORY is not set
# CONFIG_BLACKBOX_USE_PSTORE_BLK_DEBUG is not set
# CONFIG_BLACKBOX_STORAGE_BY_RAW_PARTITION is not set
# end of Blackbox Options

#
# Android
#
CONFIG_BINDER_TRANSACTION_PROC_BRIEF=y

#
# OpenHarmony HDF drivers
#
CONFIG_DRIVERS_HDF=y
CONFIG_HDF_SUPPORT_LEVEL=2
CONFIG_DRIVERS_HDF_PLATFORM=y
CONFIG_DRIVERS_HDF_PLATFORM_GPIO=y
CONFIG_DRIVERS_HDF_PLATFORM_I2C=y
CONFIG_DRIVERS_HDF_PLATFORM_SPI=y
CONFIG_DRIVERS_HDF_PLATFORM_UART=y
CONFIG_DRIVERS_HDF_PLATFORM_PWM=y
CONFIG_DRIVERS_HDF_PLATFORM_ADC=y
CONFIG_DRIVERS_HDF_PLATFORM_RTC=y
CONFIG_DRIVERS_HDF_PLATFORM_TRACE=y
CONFIG_DRIVERS_HDF_PLATFORM_DUMPER=y
CONFIG_DRIVERS_HDF_DISP=y
CONFIG_DRIVERS_HDF_SENSOR=y
CONFIG_DRIVERS_HDF_USB_PNP_NOTIFY=y
CONFIG_DRIVERS_HDF_AUDIO=y
CONFIG_DRIVERS_HDF_VIBRATOR=y
CONFIG_DRIVERS_HDF_LIGHT=y

#
# Access Token ID
#
CONFIG_ACCESS_TOKENID=y

#
# HMDFS — OHOS distributed filesystem.  Built-in so storage_daemon's
# `-t hmdfs` mounts (storage_mount_info.json) and os_account's
# /mnt/hmdfs/<uid>/account mount succeed at user activation — without the
# driver those mounts fail ENODEV and abort the per-user mount sequence.
# Source is dropped into fs/hmdfs/ by build_kernel.sh (hmdfs.patch).
#
# ENCRYPTION is left off: it `depends on TLS` and only covers the
# cross-device socket transport, which this single-device build never
# uses — the account mount is purely device-local.
#
CONFIG_HMDFS_FS=y
# CONFIG_HMDFS_FS_ENCRYPTION is not set
CONFIG_HMDFS_FS_PERMISSION=y

#
# SHAREFS — OHOS share filesystem (stacking fs that gives normal apps a
# view of /storage/Users).  Built-in so storage_daemon's `-t sharefs`
# mounts from storage_mount_info.json succeed at user activation.  Source
# is dropped into fs/sharefs/ by build_kernel.sh.
#
# SUPPORT_OVERRIDE makes sharefs_permission() return 0 — access defers to
# the lower (ext4) filesystem instead of sharefs's per-app isolation model.
# Without it, sharefs sets every level-1 dir (Download/Documents/...) to
# mode 0550 owned by uid <userId>*200000, so a normal app (e.g. VLC,
# without FILE_ACCESS_COMMON_DIR) is "other" and cannot even traverse into
# a picked file's directory — file_api's OpenByFileDataUri then sees
# access()!=0 and misroutes the open to MediaLibrary, which fails.  This
# build has no per-app file isolation (single-user dev posture), so
# deferring to the lower ext4 perms (0771 dirs, 0644 files) is correct.
#
CONFIG_SHARE_FS=y
CONFIG_SHAREFS_SUPPORT_OVERRIDE=y

#
# Unified Collection
#
CONFIG_UNIFIED_COLLECTION=y

#
# Hyperhold — OHOS background anon-memory reclaim/compression (zswapd +
# zram-group + eswap backing).  Ported into the MT6789 kernel by
# patches/kernel-source/hyperhold_patch.sh (copies the new source files from
# the in-tree OHOS reference kernel/linux/linux-5.10) + hyperhold.patch
# (the core mm/zram edits).
#
# Prerequisites: ZRAM + ZSMALLOC must be BUILT-IN (=y).  The base gx4.config
# sets them =m, but HYPERHOLD_ZSWAPD and ZRAM_GROUP are bool symbols compiled
# into vmlinux and so cannot depend on a modular ZRAM — leaving ZRAM=m makes
# Kconfig silently drop them.  openharmony.config is merged last, so these win.
#
CONFIG_ZRAM=y
CONFIG_ZSMALLOC=y
CONFIG_HYPERHOLD=y
# HYPERHOLD_DEBUG gates the zswapd parameter cgroup interface (memory.* knobs
# the OHOS memory manager writes to tune watermarks/ratios), not just debug —
# OHOS reference devices (e.g. unionpi_tiger) ship it =y.  It also defines the
# eswap_info cftype handler that zswapd_control.c references unconditionally.
CONFIG_HYPERHOLD_DEBUG=y
CONFIG_HYPERHOLD_ZSWAPD=y
CONFIG_HYPERHOLD_MEMCG=y
CONFIG_ZRAM_GROUP=y
# FILE_LRU is the most invasive piece — it splits file/anon onto separate LRUs
# and reroutes core reclaim through memcg_reclaim.c.  The code is ported and
# compiles, but it is left OFF for first bring-up (zswapd + memcg + zram-group
# already deliver the core compression win).  Flip to =y once the base boots
# stably on-device.
# CONFIG_HYPERHOLD_FILE_LRU is not set

#
# HCK
#
CONFIG_HCK=y
CONFIG_HCK_VENDOR_HOOKS=y

CONFIG_ARCH_SPRD=n
