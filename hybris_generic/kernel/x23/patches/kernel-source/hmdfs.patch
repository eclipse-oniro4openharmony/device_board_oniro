+
+enum TCP_KVEC_FILE_ELE_INDEX {
+	TCP_KVEC_FILE_PARA = 1,
+	TCP_KVEC_FILE_CONTENT = 2,
+};
+
+enum TCP_KVEC_TYPE {
+	TCP_KVEC_ELE_SINGLE = 1,
+	TCP_KVEC_ELE_DOUBLE = 2,
