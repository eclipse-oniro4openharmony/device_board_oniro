+		list_for_each_entry(conn_impl, &peer->conn_impl_list, list) {
+			tcp = conn_impl->connect_handle;
+			size += snprintf(buf + size, PAGE_SIZE - size,
+					  "socket_fd: %d\n", tcp->fd);
+			size += snprintf(buf + size, PAGE_SIZE - size,
+					"\tsend_msg %d \tsend_bytes %llu\n",
