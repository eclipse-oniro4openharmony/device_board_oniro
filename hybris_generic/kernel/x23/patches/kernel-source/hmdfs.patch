+struct hmdfs_getattr_ret {
+	/*
+	 * if stat->result_mask is 0, it means this remote getattr failed with
+	 * look up, see details in hmdfs_server_getattr.
+	 */
+	struct kstat stat;
+	uint32_t i_flags;
+	uint64_t fsid;
+};
