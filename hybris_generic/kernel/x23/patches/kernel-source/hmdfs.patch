+/*
+ * in order to distinguish from vfs, we define our own bitmask, this should
+ * covert to vfs bitmask while calling vfs apis
+ */
+#define HMDFS_LOOKUP_REVAL 0x1
+
+enum HMDFS_FILE_TYPE {
+	HM_REG = 0,
+	HM_SYMLINK = 1,
+	HM_SHARE = 2,
+
+	HM_MAX_FILE_TYPE = 0XFF
