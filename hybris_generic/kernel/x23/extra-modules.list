# MT6789 + MT6366 + AWINIC AW883xx audio stack.  These are second-stage
# (Android /vendor/lib/modules) modules — Halium's vendor_boot modules.load
# doesn't carry them, so native boot never loads them and no soundcard
# registers.  init.x23.cfg insmods them at pre-init in dependency order.
# See phase_n9_firmware_peripherals.md N9.5.
nvmem-mt635x-efuse.ko
mtk-afe-external.ko
scp.ko
adsp.ko
mtk-scp-audiocommon.ko
audio_ipi.ko
mtk-scp-audio.ko
snd-soc-audiodsp-common.ko
mtk-scp-ultra.ko
snd-soc-mtk-scp-ultra.ko
rps_perf.ko
ccmni.ko
ccci_util_lib.ko
ccci_auxadc.ko
ccci_md_all.ko
snd-soc-mtk-common.ko
mtk-sp-spk-amp.ko
smartpa.ko
mt6358-accdet.ko
snd-soc-mt6366.ko
snd-soc-mt6789-afe.ko
mtk-btcvsd.ko
mt6789-mt6366.ko

# MT6789 connsys (MediaTek WMT) WiFi stack.  Same second-stage-module
# problem as the audio + GPU stacks: the connsys driver set lives in the
# Android vendor_dlkm partition (/vendor/lib/modules), which native boot
# does not carry or load.  init.x23.cfg insmods them at pre-init in
# dependency order; `wmt_drv` must be followed by the wmtdetect-init
# helper (kernel WMT_init) before the wlan modules.  cfg80211.ko is
# already in Halium's vendor_boot modules.load, so it is not listed here.
# See phase_n9_firmware_peripherals.md N9.2.
connadp.ko
connfem.ko
btif_drv.ko
wmt_drv.ko
mddp.ko
wmt_chrdev_wifi.ko
wlan_drv_gen4m_6789.ko

# MT6789 (ISP6s) camera + image-sensor stack.  Same vendor_dlkm pattern
# as GPU (N8.11), audio (N9.5), WiFi (N9.2): Halium ships these in
# vendor_dlkm and loads them from second-stage init; native boot has no
# second-stage init, so /dev/video* + /dev/kd_camera_hw never appear.
# init.x23.cfg insmods them at pre-init in dep-resolved order, see
# phase_n12_camera_modulemap.md.
#
# TEE chain (transitive dep of camera_mem.ko via mtk_sec_heap.ko for the
# secure DMA-BUF heap):
gz_trusty_mod.ko
gz_ipc_mod.ko
mcDrvModule.ko
gz_tz_system.ko
iommu_gz.ko
trusted_mem.ko
mtk_sec_heap.ko
# Camera ISP6s + image-sensor v4l2 framework + JPEG:
archcounter_timesync.ko
v4l2-fwnode.ko
imgsensor-glue.ko
mtk_ccu.ko
imgsensor.ko
imgsensor_isp6s.ko
cam_qos.ko
camera_isp.ko
camera_mem.ko
camera_dip_isp6s.ko
camera_dpe_isp60.ko
camera_mfb_isp6s.ko
camera_rsc_isp60.ko
camera_wpe_isp6s.ko
camera_pda.ko
camera_eeprom.ko
camera_af_media.ko
mtk_jpeg.ko
