From e60eebdf9447ee81f2a51be8eb2026f38ad34936 Mon Sep 17 00:00:00 2001
From: Francesco Pham <francesco.pham1@h-partners.com>
Date: Mon, 13 Apr 2026 22:37:43 +0000
Subject: [PATCH] integration_verification: register hybris_generic VDI libs in
 deps guard rules
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

passthrough_info.json: register libdisplay_buffer_vdi_impl.z.so and
libdisplay_composer_vdi_impl.z.so from device/soc/oniro/hybris_generic as
passthrough HAL implementations. Required by the deps_guard passthrough
allowlist check during builds with integration verification enabled.

chipsetsdk_dep_whitelist.json: whitelist the hybris_generic VDI libraries'
dependencies on libhybris internals (libgralloc.z.so, libhwc2.z.so, etc.)
which reside in system/lib64/libhybris/ — a non-standard path that would
otherwise fail the chipsetsdk dependency check.

Part of Phase 5 (libhybris integration & HAL bridge) for hybris_generic.

Change-Id: I85823334c979ac78360b0b8dc4621967fb1e08d9
---
 .../rules/Passthrough/passthrough_info.json   | 12 +++++++
 .../rules/chipsetsdk_dep_whitelist.json       | 35 +++++++++++++++++++
 2 files changed, 47 insertions(+)

diff --git a/tools/deps_guard/rules/Passthrough/passthrough_info.json b/tools/deps_guard/rules/Passthrough/passthrough_info.json
index be6f7b5..6633297 100755
--- a/tools/deps_guard/rules/Passthrough/passthrough_info.json
+++ b/tools/deps_guard/rules/Passthrough/passthrough_info.json
@@ -59,6 +59,18 @@
         "path": "//device/soc/rockchip/rk3568/hardware/display:libdisplay_buffer_vdi_impl",
         "headers": []
     },
+    {
+        "name": "hdf:libdisplay_buffer_vdi_impl",
+        "so_file_name": "libdisplay_buffer_vdi_impl.z.so",
+        "path": "//device/soc/oniro/hybris_generic/hardware/display:libdisplay_buffer_vdi_impl",
+        "headers": []
+    },
+    {
+        "name": "hdf:libdisplay_composer_vdi_impl",
+        "so_file_name": "libdisplay_composer_vdi_impl.z.so",
+        "path": "//device/soc/oniro/hybris_generic/hardware/display:libdisplay_composer_vdi_impl",
+        "headers": []
+    },
     {
         "name": "hdf:libusb_host_interface_service_2.0",
         "so_file_name": "libusb_host_interface_service_2.0.z.so",
diff --git a/tools/deps_guard/rules/chipsetsdk_dep_whitelist.json b/tools/deps_guard/rules/chipsetsdk_dep_whitelist.json
index 13306b3..483fa03 100644
--- a/tools/deps_guard/rules/chipsetsdk_dep_whitelist.json
+++ b/tools/deps_guard/rules/chipsetsdk_dep_whitelist.json
@@ -4773,6 +4773,41 @@
         "dep_file_path": "system/lib/chipset-sdk/libhilog.so",
         "description": "lib libdisplay_buffer_vdi_impl.z.so with innerapi_tags [passthrough] deps wrong lib libhilog.so contains innerapi_tags [chipsetsdk]"
     },
+    {
+        "so_file_name": "libdisplay_buffer_vdi_impl.z.so",
+        "so_file_path": "vendor/lib64/passthrough/libdisplay_buffer_vdi_impl.z.so",
+        "dep_file_name": "libgralloc.z.so",
+        "dep_file_path": "system/lib64/libhybris/libgralloc.z.so",
+        "description": "hybris_generic: libdisplay_buffer_vdi_impl.z.so (passthrough) depends on libhybris libgralloc (system-only)"
+    },
+    {
+        "so_file_name": "libdisplay_buffer_vdi_impl.z.so",
+        "so_file_path": "vendor/lib64/passthrough/libdisplay_buffer_vdi_impl.z.so",
+        "dep_file_name": "libhybris-common.z.so",
+        "dep_file_path": "system/lib64/libhybris/libhybris-common.z.so",
+        "description": "hybris_generic: libdisplay_buffer_vdi_impl.z.so (passthrough) depends on libhybris-common (system-only)"
+    },
+    {
+        "so_file_name": "libdisplay_composer_vdi_impl.z.so",
+        "so_file_path": "vendor/lib64/passthrough/libdisplay_composer_vdi_impl.z.so",
+        "dep_file_name": "libhwc2.z.so",
+        "dep_file_path": "system/lib64/libhybris/libhwc2.z.so",
+        "description": "hybris_generic: libdisplay_composer_vdi_impl.z.so (passthrough) depends on libhybris libhwc2 (system-only)"
+    },
+    {
+        "so_file_name": "libdisplay_composer_vdi_impl.z.so",
+        "so_file_path": "vendor/lib64/passthrough/libdisplay_composer_vdi_impl.z.so",
+        "dep_file_name": "libhybris-common.z.so",
+        "dep_file_path": "system/lib64/libhybris/libhybris-common.z.so",
+        "description": "hybris_generic: libdisplay_composer_vdi_impl.z.so (passthrough) depends on libhybris-common (system-only)"
+    },
+    {
+        "so_file_name": "libdisplay_composer_vdi_impl.z.so",
+        "so_file_path": "vendor/lib64/passthrough/libdisplay_composer_vdi_impl.z.so",
+        "dep_file_name": "libhilog.so",
+        "dep_file_path": "system/lib64/chipset-sdk/libhilog.so",
+        "description": "hybris_generic: libdisplay_composer_vdi_impl.z.so (passthrough) depends on libhilog (chipsetsdk)"
+    },
     {
         "so_file_name": "libmemory_tracker_interface_service_1.0.z.so",
         "so_file_path": "vendor/lib/passthrough/libmemory_tracker_interface_service_1.0.z.so",
-- 
