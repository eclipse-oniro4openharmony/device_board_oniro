From 5e91734c0aab1b0bbf78e3b12420977f69e0e94d Mon Sep 17 00:00:00 2001
From: Francesco Pham <francesco.pham1@h-partners.com>
Date: Mon, 13 Apr 2026 22:36:59 +0000
Subject: [PATCH 3/4] init: propagate container shutdown/reboot to host via
 flag file
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Inside an LXC PID namespace, reboot() from container-init only terminates
the namespace — the host (Ubuntu Touch on Volla X23/mimir) never powers off
or reboots. This commit adds a static helper WriteHostShutdownRequest() in
reboot.c that, when InContainerMode() is true, writes "poweroff" or "reboot"
to /ohos-host-action before the existing reboot syscall.

/ohos-host-action is a bind mount of /run/ohos-host-action on the host,
created fresh by start-ohos.sh on every container start. A new LXC post-stop
hook (ohos-post-stop.sh) reads the flag after the container exits and calls
systemctl poweroff / systemctl reboot. An empty flag (crash, manual lxc-stop,
or host-initiated teardown) is a safe no-op.

Part of Phase 11 Fix 2 (container → host shutdown propagation) for
hybris_generic.

Change-Id: I2c4f7c8d69b85eb45d3ebcade422b560d5503b5d
---
 services/modules/reboot/reboot.c | 40 ++++++++++++++++++++++++++++++++
 1 file changed, 40 insertions(+)

diff --git a/services/modules/reboot/reboot.c b/services/modules/reboot/reboot.c
index 7410d765..3e5dd8ac 100644
--- a/services/modules/reboot/reboot.c
+++ b/services/modules/reboot/reboot.c
@@ -31,6 +31,44 @@
 #define BUFF_SIZE 256
 #define POWEROFF_REASON_DEV_PATH    "/proc/poweroff_reason"
 
+/*
+ * hybris_generic (LXC container) hook: when OHOS runs as an LXC container the
+ * kernel turns the reboot() syscall from container-init into termination of the
+ * container's PID namespace, so the host (e.g. Ubuntu Touch on Volla X23) never
+ * powers off or reboots. To propagate the intent we write the requested action
+ * to a bind-mounted flag file; the host-side lxc post-stop hook reads it and
+ * calls systemctl poweroff / systemctl reboot. If the flag file is absent (not
+ * running under hybris_generic, or the mount failed) this is a silent no-op.
+ */
+#define OHOS_HOST_ACTION_PATH "/ohos-host-action"
+
+static void WriteHostShutdownRequest(const char *action)
+{
+    if (action == NULL) {
+        return;
+    }
+    if (InContainerMode() == 0) {
+        return;
+    }
+    if (access(OHOS_HOST_ACTION_PATH, F_OK) != 0) {
+        PLUGIN_LOGI("WriteHostShutdownRequest: %s not present, skipping", OHOS_HOST_ACTION_PATH);
+        return;
+    }
+    int fd = open(OHOS_HOST_ACTION_PATH, O_WRONLY | O_TRUNC | O_CLOEXEC);
+    if (fd < 0) {
+        PLUGIN_LOGW("WriteHostShutdownRequest: open %s failed errno=%d", OHOS_HOST_ACTION_PATH, errno);
+        return;
+    }
+    size_t len = strlen(action);
+    ssize_t written = write(fd, action, len);
+    if (written != (ssize_t)len) {
+        PLUGIN_LOGW("WriteHostShutdownRequest: write %s failed errno=%d", action, errno);
+    } else {
+        PLUGIN_LOGI("WriteHostShutdownRequest: wrote %s to %s", action, OHOS_HOST_ACTION_PATH);
+    }
+    close(fd);
+}
+
 static int WritePowerOffReason(const char* reason)
 {
     PLUGIN_CHECK(reason != NULL, return -1, "WritePowerOffReason: reason is NULL\n");
@@ -91,6 +129,7 @@ static int DoReboot(int id, const char *name, int argc, const char **argv)
     ParseRebootReason(name, argc, argv);
     // clear misc
     (void)UpdateMiscMessage(NULL, "reboot", NULL, NULL);
+    WriteHostShutdownRequest("reboot");
     return DoRoot_("reboot", RB_AUTOBOOT);
 }
 
@@ -152,6 +191,7 @@ PLUGIN_STATIC int DoRebootShutdown(int id, const char *name, int argc, const cha
     ParseRebootReason(name, argc, argv);
     // clear misc
     (void)UpdateMiscMessage(NULL, "reboot", NULL, NULL);
+    WriteHostShutdownRequest("poweroff");
     const size_t len = strlen("reboot,");
     const char *cmd = strstr(argv[0], "reboot,");
     if (cmd != NULL && strlen(cmd) > len) {
