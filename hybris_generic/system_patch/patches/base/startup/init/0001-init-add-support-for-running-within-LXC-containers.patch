+// Check if in container mode.
+int InContainerMode(void)
+{
+#ifdef OHOS_LITE
+    return 0;
+#else
+    char *container = getenv("container");
+    if (container != NULL) {
+        return 1;
+    }
+    return 0;
+#endif
