diff --git a/services/init/init_cgroup.c b/services/init/init_cgroup.c
index 7104ba25..ed9e8e2c 100644
--- a/services/init/init_cgroup.c
+++ b/services/init/init_cgroup.c
@@ -120,6 +120,9 @@ static void RmdirTimer(Service *service, uint64_t timeout)
 
 int ProcessServiceDied(Service *service)
 {
+    if (InContainerMode() != 0) {
+        return 0;
+    }
     INIT_CHECK_RETURN_VALUE(service != NULL, -1);
     INIT_CHECK_RETURN_VALUE(service->pid != -1, 0);
     INIT_CHECK_RETURN_VALUE(service->isCgroupEnabled, 0);
@@ -136,6 +139,9 @@ int ProcessServiceDied(Service *service)
 
 int ProcessServiceAdd(Service *service)
 {
+    if (InContainerMode() != 0) {
+        return 0;
+    }
     INIT_CHECK_RETURN_VALUE(service != NULL, -1);
     INIT_CHECK_RETURN_VALUE(service->isCgroupEnabled, 0);
     char path[PATH_MAX] = {};
diff --git a/services/init/init_common_cmds.c b/services/init/init_common_cmds.c
index 75e96f3f..25c927fa 100644
--- a/services/init/init_common_cmds.c
+++ b/services/init/init_common_cmds.c
@@ -330,6 +330,9 @@ static int SetOwner(const char *file, const char *ownerStr, const char *groupStr
 
 static void DoChown(const struct CmdArgs *ctx)
 {
+    if (InContainerMode() != 0) {
+        return;
+    }
     // format: chown owner group /xxx/xxx/xxx
     const int pathPos = 2;
     int ret = SetOwner(ctx->argv[pathPos], ctx->argv[0], ctx->argv[1]);
@@ -392,6 +395,9 @@ static void DoMkDir(const struct CmdArgs *ctx)
 
 static void DoChmod(const struct CmdArgs *ctx)
 {
+    if (InContainerMode() != 0) {
+        return;
+    }
     // format: chmod xxxx /xxx/xxx/xxx
     mode_t mode = strtoul(ctx->argv[0], NULL, OCTAL_TYPE);
     if (mode == 0) {
@@ -445,6 +451,9 @@ static int GetMountFlag(unsigned long *mountflag, const char *targetStr, const c
 
 static void DoMount(const struct CmdArgs *ctx)
 {
+    if (InContainerMode() != 0) {
+        return;
+    }
     INIT_ERROR_CHECK(ctx->argc <= SPACES_CNT_IN_CMD_MAX, return, "Invalid arg number");
     // format: fileSystemType source target mountFlag1 mountFlag2... data
     int index = 0;
diff --git a/services/init/standard/init_service.c b/services/init/standard/init_service.c
index 4c41041b..755c97d1 100644
--- a/services/init/standard/init_service.c
+++ b/services/init/standard/init_service.c
@@ -308,6 +308,10 @@ void GetAccessToken(void)
 
 void IsEnableSandbox(void)
 {
+    if (InContainerMode() != 0) {
+        g_enableSandbox = false;
+        return;
+    }
     char value[MAX_BUFFER_LEN] = {0};
     unsigned int len = MAX_BUFFER_LEN;
     if (SystemReadParam("const.sandbox", value, &len) == 0) {
@@ -319,6 +323,9 @@ void IsEnableSandbox(void)
 
 int SetServiceEnterSandbox(const Service *service, const char *execPath)
 {
+    if (InContainerMode() != 0) {
+        return 0;
+    }
     if ((service->attribute & SERVICE_ATTR_WITHOUT_SANDBOX) == SERVICE_ATTR_WITHOUT_SANDBOX) {
         return 0;
     }
