From 96d0c5da72db0e3524501f8fdf397eec724bd17e Mon Sep 17 00:00:00 2001
From: Francesco Pham <francesco.pham1@h-partners.com>
Date: Mon, 13 Apr 2026 22:36:01 +0000
Subject: [PATCH] appspawn: add hybris env vars, /android+/apex sandbox mounts,
 SELinux guards

Three changes for hybris_generic LXC container support:

1. appspawn.cfg: inject hybris environment variables into spawned processes:
   LIBEGL, LIBGLESV2, HYBRIS_LD_LIBRARY_PATH, LD_LIBRARY_PATH, and
   HYBRIS_EGLPLATFORM=ohos so spawned apps find Mali EGL via libhybris.

2. appdata-sandbox.json: bind-mount /android and /apex into the app sandbox
   so hybris can dlopen Android vendor libraries. Also adds /data/log/sanitizer.

3. appspawn_adapter.cpp: guard CheckSpecialSpawnMode and LoadSeLinuxConfig
   with #ifdef WITH_SELINUX to allow building without SELinux support.

Phase 6.14 (launcher/HAP install) and Phase 8.18 (webview/nweb fix) for
hybris_generic.

Change-Id: I1f4110344495ec61a018b314f63b58bffb4a8a4a
---
 appdata-sandbox.json                | 15 +++++++++++++++
 appspawn.cfg                        |  9 ++++++++-
 modules/common/appspawn_adapter.cpp |  8 ++++++++
 3 files changed, 31 insertions(+), 1 deletion(-)

diff --git a/appdata-sandbox.json b/appdata-sandbox.json
index b0df2499..72c9ae64 100644
--- a/appdata-sandbox.json
+++ b/appdata-sandbox.json
@@ -213,6 +213,21 @@
                     "sandbox-path" : "/data/storage/el2/media",
                     "sandbox-flags" : [ "bind", "rec" ],
                     "check-action-status": "false"
+                }, {
+                    "src-path" : "/android",
+                    "sandbox-path" : "/android",
+                    "sandbox-flags" : [ "bind", "rec" ],
+                    "check-action-status": "false"
+                }, {
+                    "src-path" : "/apex",
+                    "sandbox-path" : "/apex",
+                    "sandbox-flags" : [ "bind", "rec" ],
+                    "check-action-status": "false"
+                }, {
+                    "src-path" : "/data/log/sanitizer",
+                    "sandbox-path" : "/data/log/sanitizer",
+                    "sandbox-flags" : [ "bind", "rec" ],
+                    "check-action-status": "false"
                 }, {
                     "src-path" : "/vendor/etc/passthrough",
                     "sandbox-path" : "/vendor/etc/passthrough",
diff --git a/appspawn.cfg b/appspawn.cfg
index 4e139471..3a9faf9e 100644
--- a/appspawn.cfg
+++ b/appspawn.cfg
@@ -54,7 +54,14 @@
             "sandbox" : 0,
             "start-mode" : "boot",
             "secon" : "u:r:appspawn:s0",
-            "bootevents" : "bootevent.appspawn.started"
+            "bootevents" : "bootevent.appspawn.started",
+            "env" : [
+                {"name": "LIBEGL",                 "value": "/android/vendor/lib64/egl/libGLES_mali.so"},
+                {"name": "LIBGLESV2",              "value": "/android/vendor/lib64/egl/libGLES_mali.so"},
+                {"name": "HYBRIS_LD_LIBRARY_PATH", "value": "/android/vendor/lib64:/android/system/lib64"},
+                {"name": "LD_LIBRARY_PATH",        "value": "/system/lib64/libhybris:/system/lib64"},
+                {"name": "HYBRIS_EGLPLATFORM",     "value": "ohos"}
+            ]
         }
     ]
 }
diff --git a/modules/common/appspawn_adapter.cpp b/modules/common/appspawn_adapter.cpp
index aa5504c8..f602d7f5 100644
--- a/modules/common/appspawn_adapter.cpp
+++ b/modules/common/appspawn_adapter.cpp
@@ -44,8 +44,10 @@ using GetPermissionFunc = int32_t (*)(void *, const char *);
 using namespace OHOS::Security::AccessToken;
 
 static const uint64_t TOKEN_ID_LOWMASK = 0xffffffff;
+#ifdef WITH_SELINUX
 void CheckSpecialSpawnMode(const AppSpawnMgr *content, const AppSpawningCtx *property,
     HapDomainInfo *hapDomainInfo);
+#endif
 
 int SetAppAccessToken(const AppSpawnMgr *content, const AppSpawningCtx *property)
 {
@@ -278,7 +280,11 @@ int32_t SetEnvInfo(const AppSpawnMgr *content, const AppSpawningCtx *property)
 
 int LoadSeLinuxConfig(void)
 {
+#ifdef WITH_SELINUX
     return HapContextLoadConfig();
+#else
+    return 0;
+#endif
 }
 
 uint32_t GetHostId(const AppSpawningCtx *property)
@@ -299,6 +305,7 @@ uint32_t GetHostId(const AppSpawningCtx *property)
     return hostId;
 }
 
+#ifdef WITH_SELINUX
 void CheckSpecialSpawnMode(const AppSpawnMgr *content, const AppSpawningCtx *property,
     HapDomainInfo *hapDomainInfo)
 {
@@ -318,3 +325,4 @@ void CheckSpecialSpawnMode(const AppSpawnMgr *content, const AppSpawningCtx *pro
         hapDomainInfo->hapFlags |= SELINUX_HAP_ISOLATED_RENDER;
     }
 }
+#endif
