@@ -716,6 +716,15 @@ void RSScreenManager::ProcessScreenConnected(std::shared_ptr<HdiOutput>& output)
                 __func__, id, defaultScreenId);
         defaultScreenId = id;
     }
+    // Fallback: if defaultScreenId is still INVALID after the MIPI check, this screen
+    // arrived after ProcessScreenHotPlugEvents() already set mipiCheckInFirstHotPlugEvent_=true
