     for (auto& config : configs) {
-        config.screenId = interface.GetDefaultScreenId();
+        config.screenId = WaitDefaultScreenId(interface);
         if (config.rotateScreenId >= 0) {
             config.screenId = interface.GetActiveScreenId();
             if (config.screenId > 0) {
diff --git a/frameworks/opengl_wrapper/src/EGL/egl_wrapper_display.cpp b/frameworks/opengl_wrapper/src/EGL/egl_wrapper_display.cpp
index 067d78a0c7..3c96c6fb72 100644
--- a/frameworks/opengl_wrapper/src/EGL/egl_wrapper_display.cpp
+++ b/frameworks/opengl_wrapper/src/EGL/egl_wrapper_display.cpp
@@ -397,12 +397,15 @@ EGLBoolean EglWrapperDisplay::MakeCurrentAfterHook(EGLSurface draw, EGLSurface r
 EglWrapperDisplay *EglWrapperDisplay::GetWrapperDisplay(EGLDisplay display)
 {
     WLOGD("");
-    EglWrapperDisplay *disp = reinterpret_cast<EglWrapperDisplay *>(display);
-    if (disp == &wrapperDisp_) {
-        return disp;
-    }
-    WLOGE("invalid display pointer.");
-    return nullptr;
+    if (display == EGL_NO_DISPLAY) {
+        return nullptr;
+    }
+    /* On hybris targets the EGLDisplay handle returned by the impl may differ
+     * from &wrapperDisp_ when the impl's eglGetPlatformDisplay was called
+     * directly (e.g., via eglGetProcAddress).  Since there is only one physical
+     * display, any valid (non-null) handle maps to the singleton wrapper display.
+     */
+    return &wrapperDisp_;
 }
 
 EGLDisplay EglWrapperDisplay::GetEglNativeDisplay(EGLenum platform,
diff --git a/rosen/modules/2d_graphics/src/render_context/new_render_context/render_context_gl.cpp b/rosen/modules/2d_graphics/src/render_context/new_render_context/render_context_gl.cpp
index 2634ffdde8..e700a0f99a 100644
--- a/rosen/modules/2d_graphics/src/render_context/new_render_context/render_context_gl.cpp
+++ b/rosen/modules/2d_graphics/src/render_context/new_render_context/render_context_gl.cpp
@@ -69,22 +69,20 @@ bool RenderContextGL::CheckEglExtension(const char* extensions, const char* exte
 
 EGLDisplay RenderContextGL::GetPlatformEglDisplay(EGLenum platform, void* native_display, const EGLint* attrib_list)
 {
-    static GetPlatformDisplayExt eglGetPlatformDisplayExt = NULL;
-
-    if (!eglGetPlatformDisplayExt) {
-        const char* extensions = eglQueryString(EGL_NO_DISPLAY, EGL_EXTENSIONS);
-        if (extensions &&
-            (CheckEglExtension(extensions, EGL_EXT_PLATFORM_WAYLAND) ||
-                CheckEglExtension(extensions, EGL_KHR_PLATFORM_WAYLAND))) {
-            eglGetPlatformDisplayExt = reinterpret_cast<GetPlatformDisplayExt>(
-                eglGetProcAddress(EGL_GET_PLATFORM_DISPLAY_EXT));
-        }
-    }
-
-    if (eglGetPlatformDisplayExt) {
-        return eglGetPlatformDisplayExt(platform, native_display, attrib_list);
-    }
-
+    /* Use eglGetDisplay directly rather than eglGetProcAddress("eglGetPlatformDisplayEXT").
+     *
+     * On hybris targets the OHOS EGL wrapper (libEGL.so) intercepts linked EGL symbols
+     * and forwards them to libEGL_impl.so (the hybris EGL).  However, eglGetProcAddress
+     * returns the impl's RAW function pointers — calling them bypasses the wrapper,
+     * producing an EGLDisplay that the wrapper doesn't recognise.  All subsequent EGL
+     * calls (eglInitialize, eglCreateContext, ...) go through the wrapper's validation
+     * which rejects the foreign display, leaving the thread with no EGL context.
+     *
+     * eglGetDisplay (a linked symbol) goes through the wrapper, which creates a
+     * properly wrapped display object that passes validation in all subsequent calls.
+     */
+    (void)platform;
+    (void)attrib_list;
     return eglGetDisplay(static_cast<EGLNativeDisplayType>(native_display));
 }
 
@@ -204,14 +202,19 @@ bool RenderContextGL::SetUpGpuContext(std::shared_ptr<Drawing::GPUContext> drawi
     }
 
     mHandler_ = std::make_shared<MemoryHandler>();
-    auto glesVersion = reinterpret_cast<const char*>(glGetString(GL_VERSION));
+    /* On hybris targets, calling glGetString() here crashes with SIGSEGV because
+     * the GL symbol resolves to the Android EGL's dispatch table, which has
+     * "no context" stubs that access bionic TLS — incompatible with MUSL.
+     * The version string is only used for optional GPU context tuning, so we
+     * skip it and use a safe fallback (OpenGL ES 3.2, matching the Mali G57). */
+    const char* glesVersion = "OpenGL ES 3.2";
     if (isUniRenderMode_) {
         cacheDir_ = UNIRENDER_CACHE_DIR;
     }
     Drawing::GPUContextOptions options;
     options.SetIsUniRender(isUniRenderMode_);
-    if (glesVersion != nullptr) {
-        auto size = glesVersion ? strlen(glesVersion) : 0;
+    {
+        auto size = strlen(glesVersion);
         mHandler_->ConfigureContext(&options, glesVersion, size, cacheDir_, isUniRenderMode_);
     }
 
