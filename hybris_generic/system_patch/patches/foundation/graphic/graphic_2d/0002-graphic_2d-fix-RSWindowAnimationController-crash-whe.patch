 #include "rs_trace.h"
 #include "rs_window_animation_utils.h"
 #ifdef SOC_PERF_ENABLE
@@ -32,13 +33,35 @@ using namespace AbilityRuntime;
 constexpr size_t ARGC_ONE = 1;
 constexpr size_t ARGC_TWO = 2;
 constexpr size_t ARGC_THREE = 3;
-thread_local std::unique_ptr<NativeReference> jsController_ = nullptr;
 
 RSWindowAnimationController::RSWindowAnimationController(napi_env env)
-    : env_(env),
-    handler_(std::make_shared<AppExecFwk::EventHandler>(AppExecFwk::EventRunner::GetMainEventRunner()))
+    : env_(env)
 {}
 
+void RSWindowAnimationController::PostTaskToJsThread(const std::function<void()>& task, const char* name)
+{
+    napi_env env = env_;
+    // Wrap the task in a handle scope: it creates napi values
+    // (CreateJsWindowAnimationTarget / CreateJsWindowAnimationFinishedCallback)
+    // and calls the JS callback. napi_send_event invokes this outside any
+    // native-callback scope, so without an explicit scope the value creation
+    // dereferences a null scope and SIGBUSes in libace_napi. (The window
+    // manager's own napi_send_event task gets a scope for free via
+    // NapiAsyncTask::Resolve.)
+    auto scopedTask = [env, task]() {
+        napi_handle_scope scope = nullptr;
+        if (napi_open_handle_scope(env, &scope) != napi_status::napi_ok || scope == nullptr) {
+            WALOGE("Failed to open handle scope for animation callback.");
+            return;
+        }
+        task();
+        napi_close_handle_scope(env, scope);
+    };
+    if (napi_send_event(env, scopedTask, napi_eprio_high, name) != napi_status::napi_ok) {
+        WALOGE("Failed to send event to js thread: %{public}s.", name);
+    }
+}
+
 void RSWindowAnimationController::SetJsController(napi_value jsController)
 {
     WALOGD("SetJsController.");
@@ -67,11 +90,7 @@ void RSWindowAnimationController::OnStartApp(StartingAppType type,
         controllerSptr->HandleOnStartApp(type, startingWindowTarget, finishedCallback);
     };
 
-    if (handler_ == nullptr) {
-        WALOGE("Window animation controller on start app error, handler is nullptr.");
-        return;
-    }
-    handler_->PostTask(task);
+    PostTaskToJsThread(task, "OnStartApp");
 }
 
