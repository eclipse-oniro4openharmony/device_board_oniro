 void RSWindowAnimationController::HandleOnStartApp(StartingAppType type,
@@ -384,10 +375,12 @@ void RSWindowAnimationController::CallJsFunction(const std::string& methodName,
         return;
     }
     
-    auto jsController_get = jsController_->Get();
-    napi_ref ref = reinterpret_cast<napi_ref>(jsController_get);
-    napi_value jsControllerValue = nullptr;
-    napi_get_reference_value(env_, ref, &jsControllerValue);
+    // NativeReference::Get() already returns the referenced napi_value (the JS
+    // controller object). The old code then re-interpreted that value as a
+    // napi_ref and called napi_get_reference_value on it, dereferencing a
+    // napi_value as a reference — SIGBUS in napi_get_reference_value
+    // (native_api.cpp). Use the value directly.
+    napi_value jsControllerValue = jsController_->Get();
 
     if (jsControllerValue == nullptr) {
         WALOGE("jsControllerValue is null!");
diff --git a/interfaces/kits/napi/graphic/animation/window_animation_manager/rs_window_animation_controller.h b/interfaces/kits/napi/graphic/animation/window_animation_manager/rs_window_animation_controller.h
index 8a01c8e67f..39001f99f9 100644
--- a/interfaces/kits/napi/graphic/animation/window_animation_manager/rs_window_animation_controller.h
+++ b/interfaces/kits/napi/graphic/animation/window_animation_manager/rs_window_animation_controller.h
@@ -90,8 +90,19 @@ private:
 
     void CallJsFunction(const std::string& methodName, napi_value const *argv, size_t argc);
 
+    // Dispatch a controller callback onto env_'s own JS thread via
+    // napi_send_event. The On* callbacks arrive on a binder/IPC thread; the
+    // JS callbacks and env_ are only valid on the thread that registered the
+    // controller (setController). Posting through an EventHandler bound to
+    // GetMainEventRunner() crashed (SIGBUS in libace_napi) whenever the
+    // registering thread was NOT the main event runner — e.g. a launcher
+    // window's ArkUI thread. napi_send_event always lands on env_'s thread.
+    void PostTaskToJsThread(const std::function<void()>& task, const char* name);
+
     napi_env env_;
-    std::shared_ptr<AppExecFwk::EventHandler> handler_;
+    // Owned per-controller (was a namespace thread_local, which only worked
+    // when SetJsController and the callback ran on the same thread).
+    std::unique_ptr<NativeReference> jsController_;
 };
