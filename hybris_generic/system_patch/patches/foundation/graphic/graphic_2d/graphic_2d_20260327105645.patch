 using namespace OHOS;
 
+namespace {
+// Poll GetDefaultScreenId() until render_service's screen manager has processed
+// the initial hotplug event and set a valid default screen ID.  The hotplug is
+// delivered asynchronously via a HIDL binder callback, so there is a window
+// between bootevent.renderservice.ready=true and defaultScreenId_ being set
+// where GetDefaultScreenId() returns INVALID_SCREEN_ID.
+static Rosen::ScreenId WaitDefaultScreenId(Rosen::RSInterfaces& rsInterface)
+{
+    constexpr int MAX_WAIT_RETRIES = 100;
+    Rosen::ScreenId screenId = rsInterface.GetDefaultScreenId();
+    int retryCount = 0;
+    while (screenId == Rosen::INVALID_SCREEN_ID && retryCount < MAX_WAIT_RETRIES) {
+        LOGI("WaitDefaultScreenId: still INVALID, retry %{public}d/%{public}d",
+            retryCount + 1, MAX_WAIT_RETRIES);
+        usleep(SLEEP_TIME_US);
+        screenId = rsInterface.GetDefaultScreenId();
+        ++retryCount;
+    }
+    if (screenId == Rosen::INVALID_SCREEN_ID) {
+        LOGE("WaitDefaultScreenId: timed out after %{public}d retries, screenId still INVALID",
+            MAX_WAIT_RETRIES);
+    } else {
+        LOGI("WaitDefaultScreenId: got screenId=%{public}llu after %{public}d retries",
+            (unsigned long long)screenId, retryCount);
+    }
+    return screenId;
+}
+} // namespace
+
