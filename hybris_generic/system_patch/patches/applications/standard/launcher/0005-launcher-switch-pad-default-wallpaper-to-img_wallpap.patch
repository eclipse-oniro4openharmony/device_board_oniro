From 1036466e9fae947eaef6c2ea971e0cb8eabf6f02 Mon Sep 17 00:00:00 2001
From: Francesco Pham <francesco.pham1@h-partners.com>
Date: Sat, 18 Apr 2026 21:34:25 +0000
Subject: [PATCH 5/5] launcher: switch pad default wallpaper to
 img_wallpaper_default.png

Mirror the phone wallpaper swap (commit b622170) on pad: replace the
original Huawei jpg with the PNG that's already shipped for phone, and
update StyleConstants.DEFAULT_BACKGROUND_IMAGE accordingly so the pad
EntryView renders the new wallpaper on hybris_generic.

Note: after `bm install -r` the ACE Extractor keeps a system-wide cache
keyed on hap path; newly-added entries (rename jpg -> png) fail with
`GetAsset failed: common/pics/img_wallpaper_default.png` until the cache
is evicted, which in practice means a device reboot.

Co-Authored-By: Claude Opus 4.7 (1M context) <noreply@anthropic.com>
Change-Id: I51b951995ba2b5e78b8cf40c082ad62f2f4b3151
---
 .../ets/common/constants/StyleConstants.ts    |   2 +-
 .../ets/common/pics/img_wallpaper_default.jpg | Bin 1212176 -> 0 bytes
 .../ets/common/pics/img_wallpaper_default.png | Bin 0 -> 842541 bytes
 3 files changed, 1 insertion(+), 1 deletion(-)
 delete mode 100644 product/pad/src/main/ets/common/pics/img_wallpaper_default.jpg
 create mode 100644 product/pad/src/main/ets/common/pics/img_wallpaper_default.png

diff --git a/product/pad/src/main/ets/common/constants/StyleConstants.ts b/product/pad/src/main/ets/common/constants/StyleConstants.ts
index 7eefc0b..09526fa 100644
--- a/product/pad/src/main/ets/common/constants/StyleConstants.ts
+++ b/product/pad/src/main/ets/common/constants/StyleConstants.ts
@@ -14,7 +14,7 @@
  */
 
 export default class StyleConstants {
-  static readonly DEFAULT_BACKGROUND_IMAGE = '/common/pics/img_wallpaper_default.jpg';
+  static readonly DEFAULT_BACKGROUND_IMAGE = '/common/pics/img_wallpaper_default.png';
   static readonly DEFAULT_APP_ICON_SIZE_WIDTH = 54;
   static readonly DEFAULT_APP_NAME_SIZE = 14;
   static readonly DEFAULT_APP_NAME_HEIGHT  = 36;
diff --git a/product/pad/src/main/ets/common/pics/img_wallpaper_default.jpg b/product/pad/src/main/ets/common/pics/img_wallpaper_default.jpg
deleted file mode 100644
index 2e9c9af4add4cfa704b0417982e4e0f68b5ad669..0000000000000000000000000000000000000000
