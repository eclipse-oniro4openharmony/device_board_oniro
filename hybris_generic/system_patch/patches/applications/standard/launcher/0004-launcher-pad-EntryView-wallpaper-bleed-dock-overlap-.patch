From f9a1c36ab2422c3a45a1bdc36140ddfc07edf961 Mon Sep 17 00:00:00 2001
From: Francesco Pham <francesco.pham1@h-partners.com>
Date: Sat, 18 Apr 2026 21:06:56 +0000
Subject: [PATCH 4/5] launcher: pad EntryView wallpaper bleed + dock-overlap
 fix

Mirror the phone wallpaper-bleed fix (commit b622170) on pad, and fix
the resulting dock-overlap-with-nav-bar regression on tablet form
factors:

- Add expandSafeArea([SYSTEM], [TOP, BOTTOM]) to pad EntryView's outer
  Stack so the wallpaper extends behind the status and navigation bars
  instead of leaving solid black bands.

- expandSafeArea on the Stack only extends *drawing*, not layout: the
  inner Column .height('100%') still snaps to the safe area (1120vp on
  the Volla Tablet 1600x2560 portrait, y offset 80, h 1120). The
  existing LayoutViewModel.calculateDock formula
  (mScreenHeight - mSysUIBottomHeight - mDockHeight) assumes 100% =
  full screen and produces workSpaceHeight + dockHeight = 1182vp, which
  overflows the Column by 62vp / 124px and pushes the dock pill behind
  the SystemUI nav bar window.

  Add an onAreaChange on the outer Column that publishes the actually-
  measured height to AppStorage.availableLayoutHeight and re-runs
  updateScreenInfo(). LayoutViewModel.calculateDock prefers
  availableLayoutHeight - mDockHeight when set, falling back to the
  screenHeight-based formula. This decouples the pad layout from the
  hardcoded mSysBottomHeight = 44 * screenWidth/360 heuristic (which
  gives ~97vp on the tablet vs the actual 80vp nav bar inset) and from
  the missing top-inset subtraction in the original formula.

  Phone is unaffected: when no consumer publishes availableLayoutHeight,
  calculateDock keeps the original behavior.

Verified on Volla Tablet (mimir): wallpaper renders behind both system
bars; dock pill now sits cleanly above the SystemUI nav bar pill with
no overlap; opening + returning from apps still works.

Change-Id: I18ef7d82e4bb3fcebd1e4229bf36118e04570beb
Signed-off-by: Francesco Pham <francesco.pham1@h-partners.com>
---
 .../main/ets/default/viewmodel/LayoutViewModel.ts   |  7 ++++++-
 product/pad/src/main/ets/pages/EntryView.ets        | 13 +++++++++++++
 2 files changed, 19 insertions(+), 1 deletion(-)

diff --git a/common/src/main/ets/default/viewmodel/LayoutViewModel.ts b/common/src/main/ets/default/viewmodel/LayoutViewModel.ts
index 5ac53ac..f13941d 100644
--- a/common/src/main/ets/default/viewmodel/LayoutViewModel.ts
+++ b/common/src/main/ets/default/viewmodel/LayoutViewModel.ts
@@ -168,7 +168,12 @@ export class LayoutViewModel {
       maxDockNum = maxNum - maxRecentNum;
     }
     this.mDockHeight = iconSize + 2 * dockPadding + marginBottom;
-    this.mWorkSpaceHeight = this.mScreenHeight - this.mSysUIBottomHeight - this.mDockHeight;
+    const availableH = AppStorage.get<number>('availableLayoutHeight');
+    if (availableH && availableH > 0) {
+      this.mWorkSpaceHeight = availableH - this.mDockHeight;
+    } else {
+      this.mWorkSpaceHeight = this.mScreenHeight - this.mSysUIBottomHeight - this.mDockHeight;
+    }
     let result = {
       mDockGap: dockGap,
       mIconSize: iconSize,
diff --git a/product/pad/src/main/ets/pages/EntryView.ets b/product/pad/src/main/ets/pages/EntryView.ets
index 954a4bd..cdab52a 100644
--- a/product/pad/src/main/ets/pages/EntryView.ets
+++ b/product/pad/src/main/ets/pages/EntryView.ets
@@ -213,6 +213,18 @@ struct EntryView {
       }
       .width('100%')
       .height('100%')
+      .onAreaChange((oldValue: Area, newValue: Area) => {
+        const h = newValue.height as number;
+        if (!h || h <= 0) {
+          return;
+        }
+        const prev = AppStorage.get<number>('availableLayoutHeight');
+        if (prev === h) {
+          return;
+        }
+        AppStorage.setOrCreate('availableLayoutHeight', h);
+        this.updateScreenInfo();
+      })
 
       if ((AppStorage.get<number>('openFolderStatus') as number) !== BigFolderConstants.OPEN_FOLDER_STATUS_CLOSE) {
         FolderOpenComponent();
@@ -223,5 +235,6 @@ struct EntryView {
     .backgroundImagePosition(Alignment.Center)
     .width('100%')
     .height('100%')
+    .expandSafeArea([SafeAreaType.SYSTEM], [SafeAreaEdge.TOP, SafeAreaEdge.BOTTOM])
   }
 }
