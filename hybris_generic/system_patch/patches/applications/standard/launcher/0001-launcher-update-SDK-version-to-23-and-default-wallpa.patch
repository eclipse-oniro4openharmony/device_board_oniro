From 81f54f123d82174f07aed1c5332b002ed2c4c43b Mon Sep 17 00:00:00 2001
From: Francesco Pham <francesco.pham1@h-partners.com>
Date: Mon, 13 Apr 2026 22:37:12 +0000
Subject: [PATCH] launcher: update SDK version to 23 and default wallpaper for
 hybris_generic

build-profile.json5: bump compileSdkVersion and compatibleSdkVersion from 20
to 23, and add runtimeOS=OpenHarmony. Version 23 matches the OpenHarmony 6.1
SDK used for the hybris_generic build.

hvigor/hvigor-config.json5: update hvigor and @ohos/hvigor-ohos-plugin from
3.0.9 to 5.18.5 and add modelVersion to match the current build toolchain.

img_wallpaper_default.jpg: update default wallpaper image for the hybris_generic
product.

Part of Phase 6.14 (launcher/HAP bring-up) for hybris_generic.

Change-Id: Ibafeb187d613bb5ad1befaced9d76a8f74e660ae
---
 build-profile.json5                           |   5 +++--
 hvigor/hvigor-config.json5                    |   5 +++--
 .../ets/common/pics/img_wallpaper_default.jpg | Bin 192020 -> 842541 bytes
 3 files changed, 6 insertions(+), 4 deletions(-)

diff --git a/build-profile.json5 b/build-profile.json5
index a4899b6..a7da5de 100644
--- a/build-profile.json5
+++ b/build-profile.json5
@@ -4,8 +4,9 @@
       {
         "name": "default",
         "signingConfig": "default",
-        "compileSdkVersion": 20,
-        "compatibleSdkVersion": 20
+        "compileSdkVersion": 23,
+        "compatibleSdkVersion": 23,
+        "runtimeOS": "OpenHarmony"
       }
     ],
     "signingConfigs": [
diff --git a/hvigor/hvigor-config.json5 b/hvigor/hvigor-config.json5
index 122677b..0a0234e 100644
--- a/hvigor/hvigor-config.json5
+++ b/hvigor/hvigor-config.json5
@@ -1,6 +1,7 @@
 {
-  "hvigorVersion": "3.0.9",
+  "modelVersion": "5.0.1",
+  "hvigorVersion": "5.18.5",
   "dependencies": {
-    "@ohos/hvigor-ohos-plugin": "3.0.9"
+    "@ohos/hvigor-ohos-plugin": "5.18.5"
   }
 }
\ No newline at end of file
diff --git a/product/phone/src/main/ets/common/pics/img_wallpaper_default.jpg b/product/phone/src/main/ets/common/pics/img_wallpaper_default.jpg
index de8755c60d01837c9a9097471fbde1499a762cfd..b38a640287965fc61203e6da14225ef0b5ef9a57 100644
