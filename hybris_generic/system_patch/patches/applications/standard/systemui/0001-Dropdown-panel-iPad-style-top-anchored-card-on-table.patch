@@ -36,6 +36,9 @@ const TAG = 'DropdownPanel-Control';
 @Component
 export default struct Control {
   private touchMoveCallback: Function = () => {}
+  // Layer B: when true, hide the inner status bar (used in tablet iPad-style mode
+  // where the real status bar is already visible above the floating card).
+  hideInnerStatusBar: boolean = false;
   startX: number = 0
   startY: number = 0
   @State moveX: number = 0
@@ -53,18 +56,20 @@ export default struct Control {
 
   build() {
     Column() {
-      Column() {
-        statusBar({ touchMoveCallback: (data: TouchMoveData): void => this.touchMoveCallback(data) })
+      if (!this.hideInnerStatusBar) {
