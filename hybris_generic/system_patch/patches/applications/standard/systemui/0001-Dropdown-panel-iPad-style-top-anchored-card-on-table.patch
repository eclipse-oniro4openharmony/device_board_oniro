-      })
-      .layoutWeight(0)
 
       Scroll(new Scroller()) {
         Column() {
diff --git a/product/phone/dropdownpanel/src/main/ets/pages/index.ets b/product/phone/dropdownpanel/src/main/ets/pages/index.ets
index e8c4886..a4a23b9 100644
--- a/product/phone/dropdownpanel/src/main/ets/pages/index.ets
+++ b/product/phone/dropdownpanel/src/main/ets/pages/index.ets
@@ -294,39 +294,129 @@ struct Index {
     }
   }
 
+  // Layer B: iPad-style top-anchored card on tablets (width >= 600vp).
+  // On phones we keep the original full-screen layout untouched.
+  // Each panel sets its own box size + scale so the *visible* size and the
+  // resulting font readability are tuned independently. Visible size = box * scale.
+  // Control center: icon-heavy, big resource fonts → bigger box at smaller scale.
+  // Notification: dense text, smaller resource fonts → smaller box at scale 1.0.
+  private static readonly TABLET_WIDTH_VP: number = 600;
+  private static readonly CONTROL_WIDTH_VP: number = 700;
+  private static readonly CONTROL_HEIGHT_VP: number = 1000;
+  private static readonly CONTROL_SCALE: number = 0.5;
+  private static readonly NOTIF_WIDTH_VP: number = 380;
+  private static readonly NOTIF_HEIGHT_VP: number = 600;
+  private static readonly NOTIF_SCALE: number = 1.0;
+  private static readonly PANEL_INSET_VP: number = 8;
+
+  isTabletLayout(): boolean {
+    return px2vp(this.mWidthPx) >= Index.TABLET_WIDTH_VP;
+  }
+
   build() {
-    Stack({ alignContent: Alignment.Top }) {
-      Image($r("app.media.dropdownpanel_bgc"))
-        .width('100%')
-        .height('100%')
-        .objectFit(ImageFit.Fill)
-        .blur(25)
-        .opacity(1)
-      Column() {
-        if (this.showComponentName === DropdownPanelComponentName.NOTIFICATION) {
-          Notification({ touchMoveCallback: (data: TouchMoveData): void => this.onTouchMove(data) })
-            .transition(this.mNotificationInsert)
-            .transition(this.mNotificationDelete)
-        }
-        if (this.showComponentName === DropdownPanelComponentName.CONTROL_CENTER) {
-          ControlCenterComponent({
-            touchMoveCallback: (data: TouchMoveData): void => this.onTouchMove(data)
+    if (this.isTabletLayout()) {
+      // Tablet: dim background covers full window for tap-to-dismiss; the actual panel
+      // is a card anchored to top-RIGHT (control center) or top-LEFT (notification).
+      // The Stack's alignContent is fixed to TopStart and we use Row for horizontal
+      // anchoring, so we can flip control vs notification at runtime.
+      Stack({ alignContent: Alignment.TopStart }) {
+        Column()
+          .width('100%')
+          .height('100%')
+          .backgroundColor('#A0000000')
+          .opacity(this.backgroundOpacity)
+          .onClick(() => this.hideSelf())
+
+        if (this.showComponentName !== DropdownPanelComponentName.NONE) {
+          Row() {
+            Column() {
+              if (this.showComponentName === DropdownPanelComponentName.NOTIFICATION) {
+                Notification({
+                  touchMoveCallback: (data: TouchMoveData): void => this.onTouchMove(data),
+                  hideInnerStatusBar: true
+                })
+                  .transition(this.mNotificationInsert)
+                  .transition(this.mNotificationDelete)
+              }
+              if (this.showComponentName === DropdownPanelComponentName.CONTROL_CENTER) {
+                ControlCenterComponent({
+                  touchMoveCallback: (data: TouchMoveData): void => this.onTouchMove(data),
+                  hideInnerStatusBar: true
+                })
+                  .transition(this.mControlCenterInsert)
+                  .transition(this.mControlCenterDelete)
+              }
+            }
+            .width((this.showComponentName === DropdownPanelComponentName.NOTIFICATION ? Index.NOTIF_WIDTH_VP : Index.CONTROL_WIDTH_VP) + 'vp')
+            .height((this.showComponentName === DropdownPanelComponentName.NOTIFICATION ? Index.NOTIF_HEIGHT_VP : Index.CONTROL_HEIGHT_VP) + 'vp')
+            .padding(16)
+            .borderRadius(40)
+            .clip(true)
+            .backgroundColor('#5099C8E6')
+            .backgroundBlurStyle(BlurStyle.Regular)
+            .shadow({ radius: 40, color: '#66000000', offsetX: 0, offsetY: 8 })
+            // Anchor scale to whichever side the card is on so the visible card
+            // sits flush with that screen edge after scaling. Notification panel
+            // uses scale 1.0 (text already small), control uses 0.5 (resource fonts huge).
+            .scale({
+              x: this.showComponentName === DropdownPanelComponentName.NOTIFICATION ? Index.NOTIF_SCALE : Index.CONTROL_SCALE,
+              y: this.showComponentName === DropdownPanelComponentName.NOTIFICATION ? Index.NOTIF_SCALE : Index.CONTROL_SCALE,
+              centerX: this.showComponentName === DropdownPanelComponentName.NOTIFICATION ? '0%' : '100%',
+              centerY: '0%'
+            })
+            .translate({ y: this.componentOptAreaTranslateY })
+          }
+          .width('100%')
+          .padding({
+            top: Index.PANEL_INSET_VP,
+            left: Index.PANEL_INSET_VP,
+            right: Index.PANEL_INSET_VP
           })
-            .transition(this.mControlCenterInsert)
-            .transition(this.mControlCenterDelete)
+          .justifyContent(this.showComponentName === DropdownPanelComponentName.NOTIFICATION ? FlexAlign.Start : FlexAlign.End)
+          .alignItems(VerticalAlign.Top)
+        }
+      }
+      .width('100%')
+      .height('100%')
+      .onAreaChange((e, e2) => {
+        Log.showInfo(TAG, `onAreaChange (tablet), e2: ${JSON.stringify(e2)}`);
+        this.mWidthPx = vp2px(Number(e2.width))
+      })
+    } else {
+      // Phone: original full-screen layout
+      Stack({ alignContent: Alignment.Top }) {
+        Image($r("app.media.dropdownpanel_bgc"))
+          .width('100%')
+          .height('100%')
+          .objectFit(ImageFit.Fill)
+          .blur(25)
+          .opacity(1)
+        Column() {
+          if (this.showComponentName === DropdownPanelComponentName.NOTIFICATION) {
+            Notification({ touchMoveCallback: (data: TouchMoveData): void => this.onTouchMove(data) })
+              .transition(this.mNotificationInsert)
+              .transition(this.mNotificationDelete)
+          }
+          if (this.showComponentName === DropdownPanelComponentName.CONTROL_CENTER) {
+            ControlCenterComponent({
+              touchMoveCallback: (data: TouchMoveData): void => this.onTouchMove(data)
+            })
+              .transition(this.mControlCenterInsert)
+              .transition(this.mControlCenterDelete)
+          }
         }
+        .width('100%')
+        .height(this.componentOptAreaHeightPX + 'px')
+        .translate({ y: this.componentOptAreaTranslateY })
       }
       .width('100%')
-      .height(this.componentOptAreaHeightPX + 'px')
-      .translate({ y: this.componentOptAreaTranslateY })
+      .height('100%')
+      .backgroundColor($r("app.color.default_background"))
+      .opacity(1)
+      .onAreaChange((e, e2) => {
+        Log.showInfo(TAG, `onAreaChange, e: ${JSON.stringify(e)} e2: ${JSON.stringify(e2)}`);
+        this.mWidthPx = vp2px(Number(e2.width))
+      })
     }
-    .width('100%')
-    .height('100%')
-    .backgroundColor($r("app.color.default_background"))
-    .opacity(1)
-    .onAreaChange((e, e2) => {
-      Log.showInfo(TAG, `onAreaChange, e: ${JSON.stringify(e)} e2: ${JSON.stringify(e2)}`);
-      this.mWidthPx = vp2px(Number(e2.width))
-    })
   }
 }
