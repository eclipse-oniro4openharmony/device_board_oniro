 .../ServiceExtAbility/ServiceExtAbility.ts    | 34 +++++++++++++++++++
 .../src/main/ets/pages/slidescreenlock.ets    | 15 +++-----
 .../main/ets/vm/slideScreenLockViewModel.ts   |  6 ++--
 4 files changed, 43 insertions(+), 14 deletions(-)

diff --git a/features/wallpapercomponent/src/main/ets/com/ohos/view/component/wallpaper.ets b/features/wallpapercomponent/src/main/ets/com/ohos/view/component/wallpaper.ets
index f9cec19..4687f84 100644
--- a/features/wallpapercomponent/src/main/ets/com/ohos/view/component/wallpaper.ets
+++ b/features/wallpapercomponent/src/main/ets/com/ohos/view/component/wallpaper.ets
@@ -41,6 +41,8 @@ export default struct Wallpaper {
         .height(Constants.FULL_CONTAINER_HEIGHT)
         .objectFit(ImageFit.Cover)
         .hoverEffect(HoverEffect.None)
+        .expandSafeArea([SafeAreaType.SYSTEM, SafeAreaType.CUTOUT],
+                        [SafeAreaEdge.TOP, SafeAreaEdge.BOTTOM, SafeAreaEdge.START, SafeAreaEdge.END])
     }
   }
 }
\ No newline at end of file
diff --git a/product/phone/src/main/ets/ServiceExtAbility/ServiceExtAbility.ts b/product/phone/src/main/ets/ServiceExtAbility/ServiceExtAbility.ts
index ab079fd..7027c3d 100644
--- a/product/phone/src/main/ets/ServiceExtAbility/ServiceExtAbility.ts
+++ b/product/phone/src/main/ets/ServiceExtAbility/ServiceExtAbility.ts
@@ -39,6 +39,40 @@ class ServiceExtAbility extends ServiceExtension {
                 Log.showInfo(TAG, 'get UIContext successful,' + JSON.stringify(UIContext));
                 AppStorage.SetOrCreate('UIContext', UIContext);
                 Log.showInfo(TAG, name + " window loadContent in then! ")
+                // Layer B fix: keyguard window defaults to opaque white in newer SDKs,
+                // which leaks through above/below the wallpaper (the white bars at top
+                // and bottom of the lockscreen). Force transparent AFTER loadContent so
+                // only the SlideScreenlock wallpaper layer is visible.
+                try {
+                    win.setWindowBackgroundColor("#00000000")
+                    Log.showInfo(TAG, "Set window background to transparent")
+                } catch (e) {
+                    Log.showError(TAG, "setWindowBackgroundColor failed: " + JSON.stringify(e))
+                    try { win.setBackgroundColor("#00000000") } catch (e2) {}
+                }
+                // Layer B fix: extend the lockscreen window edge-to-edge under the
+                // status bar / nav bar avoidance areas, so the wallpaper image
+                // actually fills the entire screen instead of breaking at the
+                // safe-area lines at top and bottom.
+                try {
+                    win.setWindowLayoutFullScreen(true)
+                    Log.showInfo(TAG, "Set window layout fullscreen")
+                } catch (e) {
+                    Log.showError(TAG, "setWindowLayoutFullScreen failed: " + JSON.stringify(e))
+                    try { win.setLayoutFullScreen(true) } catch (e2) {}
+                }
+                // Layer B fix: hide both system status bar and navigation bar
+                // for our own window. The keyguard window is z-order above the
+                // systemui bars and its content uses .expandSafeArea on the
+                // outer Flex, so the lockscreen draws edge-to-edge regardless
+                // of whether systemui bars are present.
+                try {
+                    win.setWindowSystemBarEnable([])
+                    Log.showInfo(TAG, "Hid system bars (own window)")
+                } catch (e) {
+                    Log.showError(TAG, "setWindowSystemBarEnable failed: " + JSON.stringify(e))
+                    try { win.setSystemBarEnable([]) } catch (e2) {}
+                }
                 win.show().then(() => {
                     Log.showInfo(TAG, "then begin " + name + " window show in then! ");
                 })
