From 7505172e2528ed2aa1c66eada950a884487f2ea8 Mon Sep 17 00:00:00 2001
From: Francesco Pham <francesco.pham1@h-partners.com>
Date: Mon, 13 Apr 2026 22:37:19 +0000
Subject: [PATCH] deviceinfo: add openharmony.config defconfig and OHOS cmdline
 parameters

Add the openharmony.config fragment to the kernel defconfig list so the
OHOS-specific kernel options (hilog driver, accesstokenid, blackbox, etc.)
are included in the Volla X23 kernel build.

Add hardware=x23 and ohos.boot.sn=0a20230726rpi to the kernel cmdline so
the OHOS init system can identify the board and generate a stable serial
number for the device.

Part of Phase 2 (kernel adaptation) for hybris_generic on Volla X23.
---
 deviceinfo | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/deviceinfo b/deviceinfo
index 84d1555..1766ce5 100644
--- a/deviceinfo
+++ b/deviceinfo
@@ -4,8 +4,8 @@ deviceinfo_codename="vidofnir"
 deviceinfo_arch="aarch64"
 deviceinfo_kernel_source="https://gitlab.com/ubports/porting/reference-device-ports/halium12/volla-x23/kernel-volla-mt6789.git"
 deviceinfo_kernel_source_branch="halium-12.0"
-deviceinfo_kernel_defconfig="gki_defconfig gx4.config entry_level.config halium.config"
-deviceinfo_kernel_cmdline="bootopt=64S3,32N2,64N2 systempart=/dev/mapper/system"
+deviceinfo_kernel_defconfig="gki_defconfig gx4.config entry_level.config halium.config openharmony.config"
+deviceinfo_kernel_cmdline="bootopt=64S3,32N2,64N2 systempart=/dev/mapper/system hardware=x23 ohos.boot.sn=0a20230726rpi"
 deviceinfo_kernel_clang_compile="true"
 deviceinfo_kernel_llvm_compile="true"
 deviceinfo_ramdisk_compression="lz4"
-- 
2.50.1

